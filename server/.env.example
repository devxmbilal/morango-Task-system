# --- Server ---
PORT=5000

# --- Database ---
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/morango_tasks?schema=public"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"

# --- Cloudinary (file uploads) ---
# Option A — single connection string (copy this from Cloudinary dashboard → API Keys):
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
#
# Option B — set the three fields separately:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
#
# Optional: folder name in Cloudinary (defaults to "morango_tasks")
# CLOUDINARY_FOLDER=morango_tasks
#
# If none of the above are set, uploads fall back to local disk (./uploads).
# That works for dev only — on stateless hosts (Render/Railway/Fly/Vercel)
# files will disappear, so production MUST use Cloudinary.
