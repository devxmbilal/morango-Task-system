datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  id             String   @id
  name           String
  color          String
  system         Boolean  @default(false)
  permAllTasks   Boolean  @default(false)
  permCreate     Boolean  @default(false)
  permTeam       Boolean  @default(false)
  permRoles      Boolean  @default(false)
  permReports    Boolean  @default(false)
  permSettings   Boolean  @default(false)
  users          User[]

  @@map("roles")
}

model User {
  id           String   @id
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  roleId       String?  @map("role_id")
  role         Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  title        String?
  color        String?
  isActive     Boolean  @default(true) @map("is_active")
  tasks        Task[]
  notifications Notification[]
  submissions          Submission[]
  reviewedSubmissions  Submission[] @relation("ReviewedSubmissions")

  @@map("users")
}

model Task {
  id          String       @id
  title       String
  description String?
  assigneeId  String?      @map("assignee_id")
  assignee    User?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  status      String       @default("todo") // "todo", "inprogress", "done"
  priority    String       @default("medium") // "low", "medium", "high", "urgent"
  tag         String       @default("Web Portal")
  createdDate DateTime     @default(now()) @map("created_date") @db.Date
  startDate   DateTime?    @map("start_date")
  dueDate     DateTime     @map("due_date")
  acceptedAt  DateTime?    @map("accepted_at")
  progress    Int          @default(0)
  referenceLinks String?   @map("reference_links") // JSON-encoded string[]
  comments    Comment[]
  attachments Attachment[]
  milestones  Milestone[]

  @@map("tasks")
}

model Milestone {
  id          Int          @id @default(autoincrement())
  taskId      String       @map("task_id")
  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?    @map("due_date")
  order       Int          @default(0)
  status      String       @default("pending") // "pending", "submitted", "approved", "rejected"
  links       String?      // JSON-encoded string[]
  createdAt   DateTime     @default(now()) @map("created_at")
  submissions Submission[]
  attachments MilestoneAttachment[]

  @@map("milestones")
}

model MilestoneAttachment {
  id          Int       @id @default(autoincrement())
  milestoneId Int       @map("milestone_id")
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  fileUrl     String    @map("file_url")
  fileName    String?   @map("file_name")

  @@map("milestone_attachments")
}

model Submission {
  id              Int                      @id @default(autoincrement())
  milestoneId     Int                      @map("milestone_id")
  milestone       Milestone                @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  userId          String                   @map("user_id")
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description     String
  links           String?                  // JSON-encoded array of URLs
  status          String                   @default("pending") // "pending", "approved", "rejected"
  reviewComment   String?                  @map("review_comment")
  reviewedById    String?                  @map("reviewed_by_id")
  reviewedBy      User?                    @relation("ReviewedSubmissions", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?                @map("reviewed_at")
  createdAt       DateTime                 @default(now()) @map("created_at")
  attachments     SubmissionAttachment[]

  @@map("submissions")
}

model SubmissionAttachment {
  id           Int        @id @default(autoincrement())
  submissionId Int        @map("submission_id")
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fileUrl      String     @map("file_url")
  fileName     String?    @map("file_name")
  kind         String     @default("submission") // "submission" | "review"

  @@map("submission_attachments")
}

model Comment {
  id         Int      @id @default(autoincrement())
  taskId     String   @map("task_id")
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorName String   @map("author_name")
  text       String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("comments")
}

model Attachment {
  id      Int    @id @default(autoincrement())
  taskId  String @map("task_id")
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileUrl String @map("file_url")

  @@map("task_attachments")
}

model Settings {
  id             Int      @id @default(1)
  companyName    String   @default("Morango AI") @map("company_name")
  accent         String   @default("#4f46e5")
  sidebarTheme   String   @default("light") @map("sidebar_theme")
  smtpHost       String?  @map("smtp_host")
  smtpPort       String?  @map("smtp_port")
  smtpUser       String?  @map("smtp_user")
  smtpPassword   String?  @map("smtp_password")
  smtpFrom       String?  @map("smtp_from")
  emailEnabled   Boolean  @default(false) @map("email_enabled")

  @@map("settings")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  taskId    String?  @map("task_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}
